{
  "name": "toolbox",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Central utility library — calculators, converters, analyzers, and productivity tools",
  "workspaces": [
    "packages/*",
    "apps/*",
    "api",
    "cli"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "benchmark": "node scripts/benchmark.mjs",
    "benchmark:json": "node scripts/benchmark.mjs --json-only",
    "generate:registry": "node scripts/generate-registry.mjs",
    "check:registry": "node scripts/generate-registry.mjs --check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.2"
}
