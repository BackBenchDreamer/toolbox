{
  "name": "@toolbox/api",
  "version": "0.1.0",
  "description": "REST API server — thin wrappers around toolbox package functions",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsup src/server.ts --format cjs --dts --clean --platform node",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/supertest": "^7.2.1",
    "supertest": "^7.2.2",
    "tsup": "^8.3.5",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@toolbox/developer": "*",
    "@toolbox/finance": "*",
    "@toolbox/registry": "*",
    "@toolbox/shared": "*",
    "@toolbox/utilities": "*",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "zod": "^3.24.1"
  }
}
