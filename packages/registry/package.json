{
  "name": "@toolbox/registry",
  "version": "0.1.0",
  "description": "Central tool registry — single source of truth for all toolbox tools",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "node ../../scripts/generate-registry.mjs --check",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run --config vitest.config.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^3.2.7",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@toolbox/shared": "*",
    "@toolbox/finance": "*",
    "@toolbox/utilities": "*",
    "@toolbox/developer": "*"
  }
}
