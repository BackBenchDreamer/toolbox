{
  "name": "@toolbox/finance",
  "version": "0.1.0",
  "description": "Financial calculators: loan, EMI, SIP, compound interest, GST",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./loan-calculator": {
      "types": "./dist/loan-calculator/index.d.ts",
      "import": "./dist/loan-calculator/index.mjs",
      "require": "./dist/loan-calculator/index.js"
    },
    "./emi-calculator": {
      "types": "./dist/emi-calculator/index.d.ts",
      "import": "./dist/emi-calculator/index.mjs",
      "require": "./dist/emi-calculator/index.js"
    },
    "./sip-calculator": {
      "types": "./dist/sip-calculator/index.d.ts",
      "import": "./dist/sip-calculator/index.mjs",
      "require": "./dist/sip-calculator/index.js"
    },
    "./compound-interest": {
      "types": "./dist/compound-interest/index.d.ts",
      "import": "./dist/compound-interest/index.mjs",
      "require": "./dist/compound-interest/index.js"
    },
    "./gst-calculator": {
      "types": "./dist/gst-calculator/index.d.ts",
      "import": "./dist/gst-calculator/index.mjs",
      "require": "./dist/gst-calculator/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "vitest run --config vitest.config.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^4.1.10",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@toolbox/shared": "*",
    "zod": "^3.24.1"
  }
}
