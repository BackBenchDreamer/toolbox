{
  "name": "@toolbox/utilities",
  "version": "0.1.0",
  "description": "General purpose utility tools: unit converter",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./unit-converter": {
      "types": "./dist/unit-converter/index.d.ts",
      "import": "./dist/unit-converter/index.mjs",
      "require": "./dist/unit-converter/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "vitest run --config vitest.config.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^4.1.10",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@toolbox/shared": "*",
    "zod": "^3.24.1"
  }
}
